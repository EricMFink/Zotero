@book{klugerSimpleJusticeHistory2011,
  title = {Simple {{Justice}}: {{The History}} of {{Brown}} v. {{Board}} of {{Education}} and {{Black America}}'s {{Struggle}} for {{Equality}}},
  shorttitle = {Simple {{Justice}}},
  author = {Kluger, Richard},
  year = {2011},
  month = aug,
  publisher = {{Knopf Doubleday Publishing Group}},
  abstract = {Simple Justice is the definitive history of the landmark case Brown v. Board of Education and the epic struggle for racial equality in this country. Combining intensive research with original interviews with surviving participants, Richard Kluger provides the fullest possible view of the human and legal drama in the years before 1954, the cumulative assaults on the white power structure that defended segregation, and the step-by-step establishment of a team of inspired black lawyers that could successfully challenge the law. Now, on the fiftieth anniversary of the unanimous Supreme Court decision that ended legal segregation, Kluger has updated his work with a new final chapter covering events and issues that have arisen since the book was first published, including developments in civil rights and recent cases involving affirmative action, which rose directly out of Brown v. Board of Education.},
