@book{cobbsMajorProblemsAmerican2016,
  title = {Major {{Problems}} in {{American History}}, {{Volume II}}},
  author = {Cobbs, Elizabeth and Blum, Edward J. and Gjerde, Jon},
  year = {2016},
  edition = {4 edition},
  publisher = {{Cengage Learning}},
