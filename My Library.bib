@incollection{heimerCompetingInstitutionsLaw2014,
  title = {Competing {{Institutions}}: {{Law}}, {{Medicine}}, and {{Family}} in {{Neonatal Intensive Care}}},
  shorttitle = {Competing {{Institutions}}},
  booktitle = {The {{Law}} and {{Society Reader II}}},
  author = {Heimer, Carol A.},
  editor = {Larson, Erik and Schmidt, Patrick},
  year = {2014},
  pages = {265--275},
  publisher = {{NYU Press}},
  abstract = {Sociolegal scholars have long acknowledged that the influence of law varies from one setting to another and that other normative systems also shape human action. Sociolegal scholars have also investigated the impact of law in organizations, where participants face a multitude of normative pressures arising from overlapping institutional jurisdictions. To clarify when the law will be especially influential and when rival normative systems will instead have more impact, we now need to look closely at how the law and other institutions interact in organizational contexts.  This article uses the competition between legal, medical, and familial institutions in neonatal intensive care},
