@article{dobbieReorganizingHigherEducation2008,
  title = {Reorganizing {{Higher Education}} in the {{United States}} and {{Canada}}: {{The Erosion}} of {{Tenure}} and the {{Unionization}} of {{Contingent Faculty}}},
  shorttitle = {Reorganizing {{Higher Education}} in the {{United States}} and {{Canada}}},
