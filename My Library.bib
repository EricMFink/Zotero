@article{shapiroProtectingCompetitionAmerican2019,
  title = {Protecting {{Competition}} in the {{American Economy}}: {{Merger Control}}, {{Tech Titans}}, {{Labor Markets}}},
  shorttitle = {Protecting {{Competition}} in the {{American Economy}}},
