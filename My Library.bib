@article{mccormickEffectFishingSuccess2014,
  title = {Effect of {{Fishing Success}} on {{Angler Satisfaction}} on a {{Central Oregon Rainbow Trout Fishery}}: {{Implications}} for {{Establishing Management Objectives}}},
  shorttitle = {Effect of {{Fishing Success}} on {{Angler Satisfaction}} on a {{Central Oregon Rainbow Trout Fishery}}},
  author = {McCormick, Joshua L. and Porter, Timothy K.},
  year = {2014},
  journal = {North American Journal of Fisheries Management},
  volume = {34},
  number = {5},
  pages = {938--944},
  issn = {1548-8675},
  doi = {10.1080/02755947.2014.932869},
  abstract = {Understanding the relationship between fish populations, fishing success, and angler satisfaction is critical for effective fisheries management. Our objectives were to quantify angler satisfaction in a fishery for Rainbow Trout Oncorhynchus mykiss in central Oregon and examine the factors influencing angler satisfaction. Multinomial logistic regression models were used to determine the effect of several variables, including fishing success, on angler satisfaction. Measures of fishing success were present in all of the top candidate models. The probability of an increase in angler satisfaction rating was positively related to mean length and number of fish caught per hour. However, younger anglers tended to have higher satisfaction ratings at lower mean length and catch rates of fish than did older anglers. These models provided information on the expected percentage of anglers that will be satisfied given the average length of fish caught and the number of fish caught per hour. These results can be used to establish quantitative, measurable, management objectives that will satisfy desired percentages of anglers and lead to more effective fisheries management. Received February 9, 2014; accepted May 27, 2014},
  copyright = {\textcopyright{} 2014 American Fisheries Society},
  langid = {english},
  keywords = {Fishing,Law},
  file = {/home/eric/MEGA/Zotero/Law/Fishing Regulation/McCormick_2014_Effect of Fishing Success on Angler Satisfaction on a Central Oregon Rainbow.pdf}
}

@incollection{mcewenLawyersMediationManagement2014,
