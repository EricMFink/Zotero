@book{kessler-harrisOutWorkHistory2003,
  title = {Out to {{Work}}: {{A History}} of {{Wage-Earning Women}} in the {{United States}}, 20th {{Anniversary Edition}}},
  shorttitle = {Out to {{Work}}},
  author = {{Kessler-Harris}, Alice},
  year = {2003},
