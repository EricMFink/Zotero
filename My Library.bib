@book{strikedebtDebtResistersOperations2014,
  title = {Debt {{Resisters}}' {{Operations Manual}}},
  author = {{Strike Debt} and Graeber, David and Caffentzis, George and Husain, Amin and Mirzoeff, Nicholas and Ross, Principal Curator of Invertebrate Palaeontology {and} Palaeobotany Andrew and Singh, Natasha and Taylor, Astra},
