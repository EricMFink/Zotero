@book{scottWeaponsWeakEveryday1987,
  title = {Weapons of the {{Weak}}: {{Everyday Forms}} of {{Peasant Resistance}}},
  shorttitle = {Weapons of the {{Weak}}},
  author = {Scott, James C.},
  year = {1987},
  month = sep,
  edition = {Reprint edition},
  publisher = {{Yale University Press}},
  address = {{New Haven}},
  abstract = {This sensitive picture of the constant and circumspect struggle waged by peasants materially and ideologically against their oppressors shows that techniques of evasion and resistance may represent the most significant and effective means of class struggle in the long run."A major contribution to peasant studies, Malaysian studies, and the literature on revolutions and class consciousness."--Benedict R. Anderson, Cornell University"The book is a splendid achievement. Because Scott listens closely to the villagers of Malaysia, he enormously expands our understanding of popular ideology and therefore of popular politics. And because he is also a brilliant analyst, he draws upon this concrete experience to develop a new critique of classical theories of ideology."\rule{1em}{1pt}Frances Fox Piven, Graduate Center of the City University of New York``An impressive work which may well become a classic.''\rule{1em}{1pt}Terence J. Byres, Times Literary Supplement``A highly readable, contextually sensitive, theoretically astute ethnography of a moral system in change\ldots. Weapons of the Weak is a brilliant book, combining a sure feel for the subjective side of struggle with a deft handling of economic and political trends.''\rule{1em}{1pt}John R. Bown, Journal of Peasant Studies``A splendid book, a worthy addition to the classic studies of Malay society and of the peasantry at large\ldots. Combines the readability of Akenfield or Pig Earth with an accessible and illuminating theoretical commentary.''\rule{1em}{1pt}A.F. Robertson, Times Higher Education Supplement``No one who wants to understand peasant society, in or out of Southeast Asia, or theories of change, should fail to read [this book].''\rule{1em}{1pt}Daniel S. Lev, Journal of Asian Studies``A moving account of the poor's refusal to accept the terms of their subordination\ldots. Disposes of the belief that theoretical sophistication and intelligible prose are somehow at odds.''\rule{1em}{1pt}Ramachandra Guha, Economic and Political Weekly``A seminally important commentary on the state of peasant studies and the global literature\ldots. This enormously rich work in Asian and comparative studies is\ldots{} an essential contribution to participatory development theory and practice.''\rule{1em}{1pt}Guy Gran, World DevelopmentJames C. Scott is professor of political science at Yale University.},
  isbn = {978-0-300-03641-1},
  langid = {english},
  keywords = {Anthropology,Protests}
}

